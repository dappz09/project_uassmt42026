# DATABASE_URL untuk Prisma (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.gnvfiofubonsfcbmwoug:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.gnvfiofubonsfcbmwoug:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# NextAuth
AUTH_SECRET="[YOUR-SECRET-KEY]"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (opsional)
STRIPE_SECRET_KEY="[YOUR-STRIPE-SECRET-KEY]"
STRIPE_PUBLISHABLE_KEY="[YOUR-STRIPE-PUBLISHABLE-KEY]"
STRIPE_WEBHOOK_SECRET="[YOUR-STRIPE-WEBHOOK-SECRET]"


# Google OAuth
GOOGLE_CLIENT_ID="[YOUR-GOOGLE-CLIENT-ID]"
GOOGLE_CLIENT_SECRET="[YOUR-GOOGLE-CLIENT-SECRET]"

# YouTube Proxy (opsional — wajib jika IP server hosting diblokir YouTube)
# Format: http://user:pass@host:port  atau  http://host:port  atau  socks5://host:port
# Kosongkan jika tidak menggunakan proxy
YOUTUBE_PROXY_URL=""

# YouTube Cookie (opsional — untuk bypass bot detection)
# Buka YouTube di browser, login, copy cookie dari DevTools > Application > Cookies
# Format: "VISITOR_INFO1_LIVE=xxx; GPS=xxx; PREF=xxx; ..."
YOUTUBE_COOKIE=""
