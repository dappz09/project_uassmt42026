generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

// ─── Auth.js (NextAuth) Tables ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String @id @default(cuid())
  sessionToken String @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Tables ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roleId        String?
  phone         String?
  address       String?   @db.Text
  city          String?
  province      String?
  country       String?
  gender        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role         Role?         @relation(fields: [roleId], references: [id])
  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  usageRecords UsageRecord[]
  notes        Note[]
  transactions Transaction[]
  auditLogs    AuditLog[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // SuperAdmin, Manager, User
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  action      String   // e.g. "create", "read", "update", "delete"
  resource    String   // e.g. "user", "setting", "feature"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@unique([action, resource])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── Subscription (Stripe) ───

enum PlanType {
  Free
  Paid
  Pro
  Enterprise
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  plan                  PlanType  @default(Free)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  stripeCurrentPeriodEnd DateTime?
  status                String    @default("active") // active, canceled, past_due, etc.
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Usage & Limits ───

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g. "api_call", "export", etc.
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

// ─── New Modules (Billing, AI Notes, Settings) ───

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  videoId   String?  
  videoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  type        PlanType @default(Free)
  price       Float    @default(0)
  interval    String   @default("month")
  features    String?  @db.Text
  
  // Relasi dengan AiModel
  aiModelId   String?
  aiModel     AiModel? @relation(fields: [aiModelId], references: [id])
  
  limitCount  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  currency      String   @default("IDR")
  status        String   
  paymentMethod String?
  invoiceId     String?  @unique
  metadata      String?  @db.Text
  planId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Float?
  discountAmount  Float?
  maxUses         Int?
  currentUses     Int      @default(0)
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AiModel {
  id        String   @id @default(cuid())
  provider  String   // openai, anthropic, google, groq, custom
  name      String   // gpt-4o, claude-3-opus
  apiKey    String   // sk-proj-...
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans     Plan[]
}

model AiCatalog {
  id            String   @id @default(cuid())
  providerName  String   // Label untuk UI (Contoh: "Google Gemini")
  providerValue String   @unique // Nilai unik (Contoh: "google")
  models        String   @db.Text // Teks JSON array berisi daftar model (Contoh: '["gemini-1.5-pro", "gemini-1.5-flash"]')
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // Relasi ke User (opsional untuk event sistem)
  action    String   // Contoh: "CREATE", "UPDATE", "DELETE", "LOGIN"
  resource  String   // Contoh: "AI_CATALOG", "USER", "PLAN"
  details   String?  @db.Text // Menyimpan JSON payload
  ipAddress String?  // Alamat IP pelaku
  userAgent String?  // Browser/Device yang digunakan
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── YouTube Summary Cache ───

model VideoSummary {
  id              String   @id @default(cuid())
  videoId         String   @unique
  title           String
  summaryText     String   @db.Text
  transcriptText  String?  @db.Text
  durationSeconds Int      @default(0)
  author          String?
  thumbnail       String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaymentGateway {
  id           String   @id @default(cuid())
  name         String   @unique // Misal: "Midtrans", "Xendit"
  providerName String   // Kode internal: "midtrans", "xendit", "manual"
  apiKey       String?  // Server Key / Secret Key
  publicApiKey String?  // Client Key / Public Key
  webhookUrl   String?  // Webhook URL endpoint
  isProduction Boolean  @default(false) 
  isActive     Boolean  @default(true)  
  instructions String?  @db.Text
  activeChannels String? @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}